{
  "expo": {
    "name": "MindSentry",
    "slug": "mindsentry",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "MindSentry uses your location to find nearby clinics and emergency services.",
        "NSCameraUsageDescription": "MindSentry uses your camera to capture video for wellness analysis.",
        "NSMicrophoneUsageDescription": "MindSentry uses your microphone to capture audio for wellness analysis."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "usesCleartextTraffic": true,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "CALL_PHONE",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "extra": {
      "apiUrl": ""
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
