# MindSentry Backend Environment Variables

# JWT Settings
SECRET_KEY=your-secret-key-change-in-production-min-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Database
# PostgreSQL (recommended)
# DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@localhost:5432/mindsentry

# SQLite fallback (local only)
DATABASE_URL=sqlite:///./mindsentry.db

# Application
DEBUG=True

# Hugging Face Inference API  (free, text emotion classification)
# Get key: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=REPLACE_WITH_NEW_HF_TOKEN

# Groq API  (free tier: 20 hrs/day audio, audio transcription via Whisper)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=REPLACE_WITH_NEW_GROQ_API_KEY
